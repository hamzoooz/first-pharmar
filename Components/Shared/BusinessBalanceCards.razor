@using FirstPharmar.Models
@using Lucide.Blazor

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-card border border-border rounded-xl p-6 shadow-sm group hover:border-primary/50 transition-all">
        <div class="flex items-center justify-between mb-4">
            <div class="h-10 w-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <Icon Name="dollar-sign" Width="20" Height="20" StrokeWidth="2.5" />
            </div>
            <span class="text-[10px] font-black text-success uppercase tracking-widest">+12.5%</span>
        </div>
        <h3 class="text-xs font-bold text-muted-foreground uppercase tracking-widest mb-1">Total Revenue</h3>
        <p class="text-2xl font-black text-foreground">UGX @Report.TotalRevenue.ToString("N0")</p>
    </div>

    <div class="bg-card border border-border rounded-xl p-6 shadow-sm group hover:border-primary/50 transition-all">
        <div class="flex items-center justify-between mb-4">
            <div class="h-10 w-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-500">
                <Icon Name="trending-up" Width="20" Height="20" StrokeWidth="2.5" />
            </div>
            <span class="text-[10px] font-black text-blue-500 uppercase tracking-widest">Growth</span>
        </div>
        <h3 class="text-xs font-bold text-muted-foreground uppercase tracking-widest mb-1">Net Income</h3>
        <p class="text-2xl font-black text-foreground">UGX @Report.NetIncome.ToString("N0")</p>
    </div>

    <div class="bg-card border border-border rounded-xl p-6 shadow-sm group hover:border-primary/50 transition-all">
        <div class="flex items-center justify-between mb-4">
            <div class="h-10 w-10 rounded-lg bg-purple-500/10 flex items-center justify-center text-purple-500">
                <Icon Name="bar-chart-3" Width="20" Height="20" StrokeWidth="2.5" />
            </div>
            <span class="text-[10px] font-black text-purple-500 uppercase tracking-widest">Active</span>
        </div>
        <h3 class="text-xs font-bold text-muted-foreground uppercase tracking-widest mb-1">Accounts Receivable</h3>
        <p class="text-2xl font-black text-foreground">UGX @Report.AccountsReceivable.ToString("N0")</p>
    </div>

    <div class="bg-card border border-border rounded-xl p-6 shadow-sm group hover:border-primary/50 transition-all">
        <div class="flex items-center justify-between mb-4">
            <div class="h-10 w-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-500">
                <Icon Name="shopping-bag" Width="20" Height="20" StrokeWidth="2.5" />
            </div>
            <span class="text-[10px] font-black text-orange-500 uppercase tracking-widest">Stock</span>
        </div>
        <h3 class="text-xs font-bold text-muted-foreground uppercase tracking-widest mb-1">Inventory Value</h3>
        <p class="text-2xl font-black text-foreground">UGX @Report.InventoryValue.ToString("N0")</p>
    </div>
</div>

@code {
    [Parameter] public FinancialReportDto Report { get; set; } = new();
}
