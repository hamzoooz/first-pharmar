@page "/stock-purchase"
@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Stock Purchase</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Procurement / Vendor Invoices / Stock Inward</p>
    </div>
    <button @onclick="ProcessPurchase" disabled="@(!_purchaseItems.Any())" class="btn-primary flex items-center gap-2 px-6 py-3 uppercase tracking-widest text-[10px]">
        <Icon Name="check-circle" Width="16" Height="16" StrokeWidth="3" /> Complete Procurement
    </button>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Purchase Form -->
    <div class="lg:col-span-4 space-y-6">
        <div class="bg-card border border-border rounded-xl shadow-sm p-6">
            <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-6">Inward Item Details</h3>
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Select Product</label>
                    <select @bind="_selectedProductId" class="input-field py-3">
                        <option value="0">Choose medication...</option>
                        @foreach (var p in _products)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Quantity</label>
                        <input type="number" @bind="_quantity" class="input-field py-3" placeholder="0" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Purchase Price</label>
                        <input type="number" @bind="_unitPrice" class="input-field py-3" placeholder="UGX" />
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Batch Expiry Date</label>
                    <input type="date" @bind="_expiryDate" class="input-field py-3" />
                </div>
                <button @onclick="AddItem" class="w-full bg-muted border border-border hover:border-primary/50 text-foreground font-bold py-3 rounded-lg text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-2 mt-4">
                    <Icon Name="plus" Width="14" Height="14" /> Add to Invoice
                </button>
            </div>
        </div>

        <div class="bg-card border border-border rounded-xl shadow-sm p-6">
            <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-6">Procurement Summary</h3>
            <div class="space-y-3">
                <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-muted-foreground">
                    <span>Total Units</span>
                    <span class="text-foreground">@_purchaseItems.Sum(i => i.Quantity)</span>
                </div>
                <div class="pt-3 border-t border-border/50 flex justify-between items-end">
                    <span class="text-xs font-black uppercase tracking-[0.2em] text-foreground">Total Value</span>
                    <span class="text-xl font-black text-primary">UGX @_purchaseItems.Sum(i => i.Quantity * i.UnitPrice).ToString("N0")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Invoice Table -->
    <div class="lg:col-span-8 bg-card border border-border rounded-xl shadow-sm overflow-hidden flex flex-col h-full">
        <div class="p-6 border-b border-border bg-muted/10">
            <h3 class="text-xs font-black uppercase tracking-widest text-foreground">Current Purchase Invoice</h3>
        </div>
        <div class="flex-1 overflow-y-auto">
            <table class="w-full text-left">
                <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                    <tr>
                        <th class="px-6 py-5">Product Details</th>
                        <th class="px-6 py-5 text-center">Qty</th>
                        <th class="px-6 py-5 text-right">Unit Cost</th>
                        <th class="px-6 py-5 text-right">Subtotal</th>
                        <th class="px-6 py-5"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @if (!_purchaseItems.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center text-muted-foreground/30">
                                <Icon Name="package" Width="48" Height="48" class="mx-auto mb-4 opacity-50" />
                                <p class="text-[10px] font-black uppercase tracking-widest">No items added to invoice</p>
                            </td>
                        </tr>
                    }
                    @foreach (var item in _purchaseItems)
                    {
                        <tr class="hover:bg-muted/30 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="font-bold text-foreground text-sm">@item.Product.Name</div>
                                <div class="text-[9px] text-muted-foreground uppercase font-medium">Expiry: @(item.ExpiryDate?.ToString("MMM dd, yyyy") ?? "N/A")</div>
                            </td>
                            <td class="px-6 py-4 text-center font-bold text-xs">@item.Quantity</td>
                            <td class="px-6 py-4 text-right text-xs">@item.UnitPrice.ToString("N0")</td>
                            <td class="px-6 py-4 text-right font-black text-primary text-xs">@((item.Quantity * item.UnitPrice).ToString("N0"))</td>
                            <td class="px-6 py-4 text-right">
                                <button @onclick="() => RemoveItem(item)" class="text-destructive opacity-0 group-hover:opacity-100 transition-opacity">
                                    <Icon Name="trash-2" Width="14" Height="14" />
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Product> _products = new();
    private List<PurchaseItem> _purchaseItems = new();
    
    private int _selectedProductId;
    private int _quantity = 0;
    private decimal _unitPrice = 0;
    private DateTime? _expiryDate = DateTime.Today.AddYears(1);

    protected override async Task OnInitializedAsync()
    {
        _products = await PharmacyService.GetProductsAsync();
    }

    private void AddItem()
    {
        var product = _products.FirstOrDefault(p => p.Id == _selectedProductId);
        if (product == null || _quantity <= 0) return;

        _purchaseItems.Add(new PurchaseItem 
        { 
            ProductId = _selectedProductId, 
            Product = product, 
            Quantity = _quantity, 
            UnitPrice = _unitPrice,
            ExpiryDate = _expiryDate
        });

        _quantity = 0;
        _unitPrice = 0;
    }

    private void RemoveItem(PurchaseItem item) => _purchaseItems.Remove(item);

    private async Task ProcessPurchase()
    {
        try
        {
            if (!_purchaseItems.Any()) return;

            foreach (var item in _purchaseItems)
            {
                var p = await PharmacyService.GetProductByIdAsync(item.ProductId);
                if (p != null)
                {
                    p.StockQuantity += item.Quantity;
                    p.PurchasePrice = item.UnitPrice;
                    p.ExpiryDate = item.ExpiryDate;
                    await PharmacyService.SaveProductAsync(p);
                }
            }
            _purchaseItems.Clear();
        }
        catch (Exception)
        {
            throw;
        }
    }

    private class PurchaseItem
    {
        public int ProductId { get; set; }
        public Product Product { get; set; } = null!;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public DateTime? ExpiryDate { get; set; }
    }
}
