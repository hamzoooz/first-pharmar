@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Suppliers Directory</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Partners / Logistics & Supply Chain</p>
    </div>
    <button @onclick="OpenAddModal" class="btn-primary flex items-center gap-2 px-6 py-3 uppercase tracking-widest text-[10px]">
        <Icon Name="plus" Width="16" Height="16" StrokeWidth="3" /> Onboard New Vendor
    </button>
</div>

<div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-border bg-muted/10">
        <div class="relative max-w-md group">
            <Icon Name="search" Width="18" Height="18" StrokeWidth="2.5" class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors" />
            <input type="text" placeholder="Search by name, contact or location..." class="w-full pl-12 pr-4 py-2.5 bg-background border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                <tr>
                    <th class="px-6 py-5">Corporate Identity</th>
                    <th class="px-6 py-5">Point of Contact</th>
                    <th class="px-6 py-5">Communication</th>
                    <th class="px-6 py-5">Email Address</th>
                    <th class="px-6 py-5 text-right">Management</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @if (_suppliers == null || !_suppliers.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-16 text-center text-muted-foreground/30">
                            <Icon Name="truck" Width="64" Height="64" StrokeWidth="1.5" class="mx-auto mb-4" />
                            <p class="text-sm font-bold uppercase tracking-widest">No vendor records available</p>
                            <p class="text-[10px] uppercase tracking-tight mt-1">Populate your supplier directory to manage procurement</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var supplier in _suppliers)
                    {
                        <tr class="hover:bg-muted/30 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="font-bold text-foreground text-sm">@supplier.Name</div>
                                <div class="text-[10px] text-muted-foreground uppercase tracking-tight truncate max-w-[200px]">@supplier.Address</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-foreground font-medium">@supplier.ContactPerson</td>
                            <td class="px-6 py-4 text-sm text-muted-foreground font-mono">@supplier.Phone</td>
                            <td class="px-6 py-4 text-sm text-muted-foreground">@supplier.Email</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @onclick="() => EditSupplier(supplier)" class="p-2 hover:bg-primary/10 text-primary rounded-lg transition-colors">
                                        <Icon Name="edit-2" Width="14" Height="14" StrokeWidth="2.5" />
                                    </button>
                                    <button class="p-2 hover:bg-destructive/10 text-destructive rounded-lg transition-colors">
                                        <Icon Name="trash-2" Width="14" Height="14" StrokeWidth="2.5" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-background/80 backdrop-blur-sm animate-fade-in">
        <div class="bg-card border border-border shadow-2xl w-full max-w-xl rounded-2xl overflow-hidden animate-slide-up">
            <div class="p-6 border-b border-border flex justify-between items-center bg-muted/10">
                <div>
                    <h3 class="text-lg font-bold text-foreground">@(_editingSupplier.Id == 0 ? "Vendor Onboarding" : "Update Vendor Profile")</h3>
                    <p class="text-[10px] text-muted-foreground uppercase tracking-widest font-medium">System / Suppliers / @(_editingSupplier.Id == 0 ? "New" : "Edit")</p>
                </div>
                <button @onclick="CloseModal" class="h-8 w-8 rounded-lg flex items-center justify-center hover:bg-muted text-muted-foreground transition-colors">
                    <Icon Name="x" Width="20" Height="20" StrokeWidth="2.5" />
                </button>
            </div>
            <div class="p-8 space-y-6">
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Corporate Entity Name *</label>
                        <input @bind="_editingSupplier.Name" type="text" class="input-field py-3" placeholder="Legal business name..." />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Authorized Representative</label>
                        <input @bind="_editingSupplier.ContactPerson" type="text" class="input-field py-3" placeholder="Full name of contact person..." />
                    </div>
                    <div class="grid grid-cols-2 gap-5">
                        <div>
                            <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Primary Contact Number</label>
                            <input @bind="_editingSupplier.Phone" type="text" class="input-field py-3 font-mono" placeholder="International format preferred..." />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Email for Correspondence</label>
                            <input @bind="_editingSupplier.Email" type="email" class="input-field py-3" placeholder="business@domain.com" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Operational Headquarters (Address)</label>
                        <textarea @bind="_editingSupplier.Address" rows="2" class="input-field py-3 resize-none" placeholder="Physical location details..."></textarea>
                    </div>
                </div>
            </div>
            <div class="p-6 bg-muted/10 border-t border-border flex gap-4">
                <button @onclick="CloseModal" class="btn-secondary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Dismiss</button>
                <button @onclick="SaveSupplier" class="btn-primary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Commit Vendor</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Supplier> _suppliers = new();
    private bool _showModal = false;
    private Supplier _editingSupplier = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        _suppliers = await PharmacyService.GetSuppliersAsync();
    }

    private void OpenAddModal()
    {
        _editingSupplier = new Supplier();
        _showModal = true;
    }

    private void EditSupplier(Supplier supplier)
    {
        _editingSupplier = new Supplier 
        { 
            Id = supplier.Id,
            Name = supplier.Name,
            ContactPerson = supplier.ContactPerson,
            Phone = supplier.Phone,
            Email = supplier.Email,
            Address = supplier.Address
        };
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveSupplier()
    {
        if (string.IsNullOrWhiteSpace(_editingSupplier.Name)) return;
        await PharmacyService.SaveSupplierAsync(_editingSupplier);
        await LoadSuppliers();
        _showModal = false;
    }
}
