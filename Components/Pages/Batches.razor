@page "/batches"
@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Batch Tracking</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Inventory / Expiry Management / Compliance</p>
    </div>
    <div class="flex gap-3">
        <div class="bg-card border border-border rounded-lg px-4 py-2 flex items-center gap-3">
            <Icon Name="alert-triangle" Width="18" Height="18" class="text-destructive" />
            <div>
                <p class="text-[9px] font-black text-destructive uppercase tracking-widest leading-none">Expiring Soon</p>
                <p class="text-lg font-black text-foreground">@_expiringSoonCount</p>
            </div>
        </div>
    </div>
</div>

<div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-border bg-muted/10 flex flex-col md:flex-row justify-between gap-4">
        <div class="relative group max-w-sm w-full">
            <Icon Name="search" Width="18" Height="18" class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors" />
            <input type="text" placeholder="Search batches by product or barcode..." @bind="_searchTerm" @bind:event="oninput"
                   class="w-full pl-12 pr-4 py-2.5 bg-background border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
        </div>
        <div class="flex gap-2">
            <button class="px-4 py-2 bg-muted border border-border rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-muted/80 transition-colors">All Batches</button>
            <button class="px-4 py-2 bg-background border border-border rounded-lg text-xs font-bold text-muted-foreground uppercase tracking-widest hover:border-primary/50 hover:text-primary transition-all">Expiring &lt; 30 Days</button>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                <tr>
                    <th class="px-6 py-5">Product Details</th>
                    <th class="px-6 py-5">Stock Level</th>
                    <th class="px-6 py-5">Expiry Status</th>
                    <th class="px-6 py-5">Compliance</th>
                    <th class="px-6 py-5 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var product in FilteredProducts)
                {
                    <tr class="hover:bg-muted/30 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="font-bold text-foreground text-sm">@product.Name</div>
                            <div class="text-[10px] text-muted-foreground font-mono">@(string.IsNullOrEmpty(product.Barcode) ? "NO-BARCODE" : product.Barcode)</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="flex-1 h-1.5 w-24 bg-muted rounded-full overflow-hidden">
                                    <div class="h-full @(product.StockQuantity < 10 ? "bg-destructive" : "bg-primary")" style="width: @(Math.Min(100, product.StockQuantity))%"></div>
                                </div>
                                <span class="text-xs font-black text-foreground">@product.StockQuantity</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            @if (product.ExpiryDate.HasValue)
                            {
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold @(product.ExpiryDate <= DateTime.Today.AddDays(30) ? "text-destructive" : "text-foreground")">
                                        @product.ExpiryDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                    <span class="text-[9px] text-muted-foreground uppercase font-medium">
                                        @((product.ExpiryDate.Value - DateTime.Today).Days) days remaining
                                    </span>
                                </div>
                            }
                            else
                            {
                                <span class="text-[10px] text-muted-foreground italic">No date set</span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            @if (product.ExpiryDate.HasValue && product.ExpiryDate <= DateTime.Today)
                            {
                                <span class="px-2 py-0.5 rounded bg-destructive/10 text-destructive text-[9px] font-black uppercase tracking-widest border border-destructive/20">Expired</span>
                            }
                            else if (product.ExpiryDate.HasValue && product.ExpiryDate <= DateTime.Today.AddDays(30))
                            {
                                <span class="px-2 py-0.5 rounded bg-orange-100 text-orange-600 text-[9px] font-black uppercase tracking-widest border border-orange-200">Critical</span>
                            }
                            else
                            {
                                <span class="px-2 py-0.5 rounded bg-success/10 text-success text-[9px] font-black uppercase tracking-widest border border-success/20">Compliant</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="p-2 hover:bg-primary/10 text-primary rounded-lg transition-colors">
                                <Icon Name="edit" Width="14" Height="14" />
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Product> _products = new();
    private int _expiringSoonCount = 0;
    private string _searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        _products = await PharmacyService.GetProductsAsync();
        _expiringSoonCount = _products.Count(p => p.ExpiryDate.HasValue && p.ExpiryDate <= DateTime.Today.AddDays(30));
    }

    private IEnumerable<Product> FilteredProducts => _products
        .Where(p => string.IsNullOrWhiteSpace(_searchTerm) || 
                   p.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   (p.Barcode != null && p.Barcode.Contains(_searchTerm)));
}
