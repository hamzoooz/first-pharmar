@page "/orders"
@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Order Queue</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Fulfillment / Dispatch / Pending Deliveries</p>
    </div>
    <div class="flex gap-2">
        <button class="px-6 py-3 bg-muted border border-border rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-muted/80 transition-colors">Manifest Export</button>
        <button class="btn-primary flex items-center gap-2 px-6 py-3 uppercase tracking-widest text-[10px]">
            <Icon Name="printer" Width="16" Height="16" /> Print Batch Labels
        </button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-card border border-border rounded-xl p-5 shadow-sm flex items-center gap-4">
        <div class="h-10 w-10 rounded-lg bg-orange-100 flex items-center justify-center text-orange-600">
            <Icon Name="clock" Width="20" Height="20" />
        </div>
        <div>
            <p class="text-[9px] font-black text-muted-foreground uppercase tracking-widest leading-none mb-1">Awaiting Pick</p>
            <p class="text-lg font-black text-foreground">14 Orders</p>
        </div>
    </div>
    <div class="bg-card border border-border rounded-xl p-5 shadow-sm flex items-center gap-4">
        <div class="h-10 w-10 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
            <Icon Name="truck" Width="20" Height="20" />
        </div>
        <div>
            <p class="text-[9px] font-black text-muted-foreground uppercase tracking-widest leading-none mb-1">In Transit</p>
            <p class="text-lg font-black text-foreground">08 Orders</p>
        </div>
    </div>
    <div class="bg-card border border-border rounded-xl p-5 shadow-sm flex items-center gap-4">
        <div class="h-10 w-10 rounded-lg bg-green-100 flex items-center justify-center text-green-600">
            <Icon Name="check-circle" Width="20" Height="20" />
        </div>
        <div>
            <p class="text-[9px] font-black text-muted-foreground uppercase tracking-widest leading-none mb-1">Delivered (Today)</p>
            <p class="text-lg font-black text-foreground">32 Orders</p>
        </div>
    </div>
</div>

<div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-border bg-muted/10 flex justify-between items-center">
        <h3 class="text-xs font-black uppercase tracking-widest text-foreground">Recent Orders Log</h3>
        <div class="flex gap-4">
            <select class="bg-background border border-border rounded-lg px-3 py-1.5 text-[10px] font-bold uppercase outline-none">
                <option>Filter: All Regions</option>
                <option>Filter: Kampala Central</option>
                <option>Filter: Entebbe</option>
            </select>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                <tr>
                    <th class="px-6 py-5">Order Reference</th>
                    <th class="px-6 py-5">Customer Account</th>
                    <th class="px-6 py-5">Items</th>
                    <th class="px-6 py-5">Value</th>
                    <th class="px-6 py-5">Status</th>
                    <th class="px-6 py-5 text-right">Fulfillment</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var sale in _sales.Take(10))
                {
                    <tr class="hover:bg-muted/30 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="font-mono font-bold text-foreground text-xs">#ORD-@sale.Id.ToString("D5")</div>
                            <div class="text-[9px] text-muted-foreground font-medium uppercase">Timestamp: @sale.SaleDate.ToString("hh:mm tt")</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-xs font-bold text-foreground">@(string.IsNullOrEmpty(sale.CustomerName) ? "RETAIL WALK-IN" : sale.CustomerName)</div>
                            <div class="text-[9px] text-muted-foreground uppercase tracking-tighter">Verified Account</div>
                        </td>
                        <td class="px-6 py-4 text-xs font-medium">@sale.Items.Count Items</td>
                        <td class="px-6 py-4 font-black text-foreground text-xs">UGX @sale.TotalAmount.ToString("N0")</td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-0.5 rounded bg-success/10 text-success text-[9px] font-black uppercase tracking-widest border border-success/20">Fulfilled</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                             <button class="px-3 py-1 bg-primary text-white rounded text-[10px] font-black uppercase tracking-widest hover:opacity-90 transition-opacity">Dispatch</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Sale> _sales = new();

    protected override async Task OnInitializedAsync()
    {
        _sales = await PharmacyService.GetSalesAsync();
    }
}
