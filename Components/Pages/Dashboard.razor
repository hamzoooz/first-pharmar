@using FirstPharmar.Services
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <!-- Total Products -->
    <div class="bg-card rounded-xl border border-border p-5 transition-all hover:shadow-md">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Total Products</span>
            <div class="h-8 w-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <Icon Name="package" Width="16" Height="16" StrokeWidth="2.5" />
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <h3 class="text-2xl font-bold text-foreground">@_stats.TotalProducts</h3>
        </div>
        <div class="mt-4 h-1 w-full bg-muted rounded-full overflow-hidden">
            <div class="h-full bg-primary" style="width: 70%"></div>
        </div>
    </div>

    <!-- Out of Stock -->
    <div class="bg-card rounded-xl border border-border p-5 transition-all hover:shadow-md">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Out of Stock</span>
            <div class="h-8 w-8 rounded-lg bg-destructive/10 flex items-center justify-center text-destructive">
                <Icon Name="alert-triangle" Width="16" Height="16" StrokeWidth="2.5" />
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <h3 class="text-2xl font-bold text-foreground">@_stats.OutOfStockCount</h3>
        </div>
        <div class="mt-4 h-1 w-full bg-muted rounded-full overflow-hidden">
            <div class="h-full bg-destructive" style="width: 100%"></div>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="bg-card rounded-xl border border-border p-5 transition-all hover:shadow-md">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Low Stock Items</span>
            <div class="h-8 w-8 rounded-lg bg-warning/10 flex items-center justify-center text-warning">
                <Icon Name="alert-triangle" Width="16" Height="16" StrokeWidth="2.5" />
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <h3 class="text-2xl font-bold text-foreground">@_stats.LowStockCount</h3>
        </div>
        <div class="mt-4 flex gap-1">
            @for(int i=0; i<5; i++) { <div class='h-1 flex-1 rounded-full @(i < 3 ? "bg-warning" : "bg-muted")'></div> }
        </div>
    </div>

    <!-- Daily Revenue -->
    <div class="bg-card rounded-xl border border-border p-5 transition-all hover:shadow-md">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Daily Revenue</span>
            <div class="h-8 w-8 rounded-lg bg-success/10 flex items-center justify-center text-success">
                <Icon Name="dollar-sign" Width="16" Height="16" StrokeWidth="2.5" />
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <h3 class="text-2xl font-bold text-foreground">UGX @_stats.DailySales.ToString("N0")</h3>
        </div>
        <p class="text-[10px] text-muted-foreground mt-2 uppercase tracking-tight">Today's Transactions</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Recent Sales Table -->
    <div class="lg:col-span-2 bg-card rounded-xl border border-border overflow-hidden">
        <div class="p-5 border-b border-border flex justify-between items-center">
            <div class="flex items-center gap-2">
                <Icon Name="history" Width="18" Height="18" StrokeWidth="2" class="text-primary" />
                <h4 class="font-bold text-foreground">Recent Transactions</h4>
            </div>
            <button class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline">Full Report</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Transaction ID</th>
                        <th class="px-6 py-4">Time</th>
                        <th class="px-6 py-4">Customer Type</th>
                        <th class="px-6 py-4 text-right">Net Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var sale in _recentSales)
                    {
                        <tr class="hover:bg-muted/30 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="font-mono text-xs text-muted-foreground group-hover:text-primary transition-colors">#@sale.Id.ToString("X").PadLeft(6, '0')</span>
                            </td>
                            <td class="px-6 py-4 text-xs font-medium text-foreground">@sale.SaleDate.ToString("hh:mm tt")</td>
                            <td class="px-6 py-4">
                                <span class="text-[10px] font-bold uppercase tracking-tight px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground">
                                    @(sale.CustomerName ?? "Cash Guest")
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="text-xs font-bold text-foreground">UGX @sale.TotalAmount.ToString("N0")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="space-y-6">
        <div class="gradient-primary rounded-xl p-6 text-white shadow-lg relative overflow-hidden group">
            <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:scale-110 transition-transform duration-500">
                <Icon Name="shopping-cart" Width="120" Height="120" StrokeWidth="1" />
            </div>
            <h4 class="font-bold mb-1 relative z-10">Quick Actions</h4>
            <p class="text-[10px] text-white/50 uppercase tracking-widest mb-4 relative z-10">Administrative Control</p>
            
            <div class="grid grid-cols-2 gap-3 relative z-10">
                <button class="bg-white/10 hover:bg-white/20 p-4 rounded-xl flex flex-col items-center gap-2 transition-all border border-white/5">
                    <div class="h-8 w-8 rounded-lg bg-white/10 flex items-center justify-center"><Icon Name="package" Width="18" Height="18" StrokeWidth="2" /></div>
                    <span class="text-[10px] font-bold uppercase tracking-tight">Add Product</span>
                </button>
                <button class="bg-white/10 hover:bg-white/20 p-4 rounded-xl flex flex-col items-center gap-2 transition-all border border-white/5">
                    <div class="h-8 w-8 rounded-lg bg-white/10 flex items-center justify-center"><Icon Name="shopping-cart" Width="18" Height="18" StrokeWidth="2" /></div>
                    <span class="text-[10px] font-bold uppercase tracking-tight">New Sale</span>
                </button>
            </div>
        </div>

        <div class="bg-card rounded-xl border border-border p-6 shadow-sm relative overflow-hidden group">
            <div class="absolute -right-2 -top-2 text-primary/5 group-hover:scale-110 transition-transform duration-500">
                <Icon Name="sparkles" Width="80" Height="80" />
            </div>
            <div class="flex items-center gap-3 mb-4">
                <div class="h-10 w-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                    <Icon Name="bot" Width="20" Height="20" StrokeWidth="2.5" />
                </div>
                <div>
                    <h4 class="font-bold text-foreground leading-none mb-1">AI Insights</h4>
                    <p class="text-[9px] text-muted-foreground uppercase tracking-widest font-bold">Predictive Analytics</p>
                </div>
            </div>
            <div class="space-y-3">
                <div class="p-3 rounded-lg bg-muted/50 border border-border text-[11px] leading-relaxed">
                    Stock for <span class="font-bold text-primary">Amoxicillin</span> is projected to run out in <span class="font-bold">4 days</span> based on current sales velocity.
                </div>
                <div class="flex items-center gap-2 text-[10px] font-bold text-primary cursor-pointer hover:underline">
                    <Icon Name="sparkles" Width="12" Height="12" /> View full analysis
                </div>
            </div>
        </div>

        <div class="bg-card rounded-xl border border-border p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h4 class="font-bold text-foreground">System Health</h4>
                <div class="h-2 w-2 rounded-full bg-success animate-pulse"></div>
            </div>
            <div class="space-y-4">
                <div class="flex justify-between items-center">
                    <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Connectivity</span>
                    <span class="text-[10px] font-bold text-success uppercase">Secured</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Local Buffer</span>
                    <span class="text-[10px] font-bold text-foreground">12.4 MB</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Auto Backup</span>
                    <span class="text-[10px] font-bold text-muted-foreground opacity-50 uppercase">Active</span>
                </div>
            </div>
            <button class="w-full mt-6 py-2 rounded-lg bg-secondary text-secondary-foreground text-[10px] font-bold uppercase tracking-widest border border-border hover:bg-muted transition-colors">
                Perform Diagnostic
            </button>
        </div>
    </div>
</div>

@code {
    private DashboardStats _stats = new();
    private List<FirstPharmar.Models.Sale> _recentSales = new();

    protected override async Task OnInitializedAsync()
    {
        _stats = await PharmacyService.GetDashboardStatsAsync();
        var sales = await PharmacyService.GetSalesAsync();
        _recentSales = sales.Take(5).ToList();
    }
}
