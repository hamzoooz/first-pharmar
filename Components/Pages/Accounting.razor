@page "/accounting"
@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService
@inject IJSRuntime JS

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Financial Intelligence</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Audit / Reporting / Analytics</p>
    </div>
    <div class="flex gap-3">
        <div class="flex items-center bg-card border border-border rounded-lg px-3 py-1.5 gap-3">
            <input type="date" @bind="_fromDate" class="bg-transparent border-none text-[10px] font-bold uppercase outline-none text-foreground" />
            <span class="text-muted-foreground text-[10px]">to</span>
            <input type="date" @bind="_toDate" class="bg-transparent border-none text-[10px] font-bold uppercase outline-none text-foreground" />
            <button @onclick="LoadData" class="text-primary hover:scale-110 transition-transform">
                <Icon Name="refresh-cw" Width="14" Height="14" />
            </button>
        </div>
        <button @onclick="PrintReport" class="btn-primary flex items-center gap-2 px-6 py-3 uppercase tracking-widest text-[10px]">
            <Icon Name="printer" Width="16" Height="16" /> Print Financials
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="h-96 flex flex-col items-center justify-center gap-4">
        <div class="animate-spin text-primary">
            <Icon Name="loader-2" Width="48" Height="48" StrokeWidth="1.5" />
        </div>
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-muted-foreground animate-pulse">Aggregating Ledger Data...</p>
    </div>
}
else
{
    <BusinessBalanceCards Report="_report" />

    <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
        <div class="flex border-b border-border bg-muted/10">
            <button @onclick='() => _activeTab = "Income"' class='px-8 py-4 text-[10px] font-black uppercase tracking-widest transition-all border-r border-border @(_activeTab == "Income" ? "bg-background text-primary border-b-2 border-b-primary" : "text-muted-foreground hover:bg-muted/50")'>Income Statement</button>
            <button @onclick='() => _activeTab = "Balance"' class='px-8 py-4 text-[10px] font-black uppercase tracking-widest transition-all border-r border-border @(_activeTab == "Balance" ? "bg-background text-primary border-b-2 border-b-primary" : "text-muted-foreground hover:bg-muted/50")'>Balance Sheet</button>
            <button @onclick='() => _activeTab = "Trial"' class='px-8 py-4 text-[10px] font-black uppercase tracking-widest transition-all border-r border-border @(_activeTab == "Trial" ? "bg-background text-primary border-b-2 border-b-primary" : "text-muted-foreground hover:bg-muted/50")'>Trial Balance</button>
        </div>

        <div class="p-8">
            @if (_activeTab == "Income")
            {
                <div class="max-w-3xl mx-auto space-y-8 animate-fade-in">
                    <section>
                        <h4 class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
                            <div class="h-1.5 w-1.5 rounded-full bg-primary"></div> Operating Revenue
                        </h4>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center py-2 border-b border-border/50">
                                <span class="text-sm font-medium text-muted-foreground">Product Sales (Cash)</span>
                                <span class="font-mono font-bold text-foreground">UGX @_report.CashRevenue.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-center py-2 border-b border-border/50">
                                <span class="text-sm font-medium text-muted-foreground">Product Sales (Mobile Money)</span>
                                <span class="font-mono font-bold text-foreground">UGX @_report.MobileMoneyRevenue.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-center py-2 border-b border-border/50">
                                <span class="text-sm font-medium text-muted-foreground">Product Sales (Credit)</span>
                                <span class="font-mono font-bold text-foreground">UGX @_report.CreditRevenue.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-center pt-4 text-base font-black text-foreground">
                                <span class="uppercase tracking-widest text-[11px]">Total Operating Revenue</span>
                                <span>UGX @_report.TotalRevenue.ToString("N0")</span>
                            </div>
                        </div>
                    </section>

                    <section>
                        <h4 class="text-[10px] font-black text-destructive uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
                            <div class="h-1.5 w-1.5 rounded-full bg-destructive"></div> Cost of Goods & Expenses
                        </h4>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center py-2 border-b border-border/50">
                                <span class="text-sm font-medium text-muted-foreground">Cost of Goods Sold (Estimated)</span>
                                <span class="font-mono font-bold text-destructive">-(UGX @_report.COGS.ToString("N0"))</span>
                            </div>
                            <div class="flex justify-between items-center py-2 border-b border-border/50">
                                <span class="text-sm font-medium text-muted-foreground">Operating Expenses (Fixed 15%)</span>
                                <span class="font-mono font-bold text-destructive">-(UGX @_report.OpEx.ToString("N0"))</span>
                            </div>
                            <div class="flex justify-between items-center pt-4 text-lg font-black text-success">
                                <span class="uppercase tracking-widest text-[11px]">Net Operating Income</span>
                                <span>UGX @_report.NetIncome.ToString("N0")</span>
                            </div>
                        </div>
                    </section>
                </div>
            }
            else if (_activeTab == "Balance")
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 animate-fade-in">
                    <div>
                        <h4 class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-6 border-b border-primary/20 pb-2">Current Assets</h4>
                        <div class="space-y-4">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-bold text-muted-foreground uppercase">Cash & Liquid Equivalents</p>
                                    <p class="text-sm font-black text-foreground">1000 - General Ledger</p>
                                </div>
                                <span class="font-mono font-bold text-foreground">UGX @_report.CashBalance.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-bold text-muted-foreground uppercase">Merchandise Inventory</p>
                                    <p class="text-sm font-black text-foreground">1300 - Stock Asset</p>
                                </div>
                                <span class="font-mono font-bold text-foreground">UGX @_report.InventoryValue.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-bold text-muted-foreground uppercase">Accounts Receivable</p>
                                    <p class="text-sm font-black text-foreground">1200 - Customer Credits</p>
                                </div>
                                <span class="font-mono font-bold text-foreground">UGX @_report.AccountsReceivable.ToString("N0")</span>
                            </div>
                            <div class="pt-6 border-t border-border flex justify-between items-center">
                                <span class="text-xs font-black uppercase tracking-widest">Total Assets</span>
                                <span class="text-xl font-black text-primary">UGX @_report.TotalAssets.ToString("N0")</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h4 class="text-[10px] font-black text-purple-500 uppercase tracking-[0.2em] mb-6 border-b border-purple-500/20 pb-2">Equity & Liabilities</h4>
                        <div class="space-y-4">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-bold text-muted-foreground uppercase">Retained Earnings</p>
                                    <p class="text-sm font-black text-foreground">3000 - Accumulated Profit</p>
                                </div>
                                <span class="font-mono font-bold text-foreground">UGX @_report.NetIncome.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-bold text-muted-foreground uppercase">Current Liabilities</p>
                                    <p class="text-sm font-black text-foreground">2000 - Accounts Payable</p>
                                </div>
                                <span class="font-mono font-bold text-foreground">UGX 0</span>
                            </div>
                            <div class="pt-6 border-t border-border flex justify-between items-center">
                                <span class="text-xs font-black uppercase tracking-widest">Total Equity</span>
                                <span class="text-xl font-black text-purple-500">UGX @_report.NetIncome.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (_activeTab == "Trial")
            {
                <div class="overflow-x-auto animate-fade-in">
                    <table class="w-full">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-left">Code</th>
                                <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-left">Account Name</th>
                                <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-right">Debit (UGX)</th>
                                <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-right">Credit (UGX)</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            <tr class="hover:bg-muted/20">
                                <td class="px-6 py-4 font-mono text-xs font-bold">1000</td>
                                <td class="px-6 py-4 text-sm font-medium">Cash & Bank</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">@_report.CashBalance.ToString("N0")</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">0</td>
                            </tr>
                            <tr class="hover:bg-muted/20">
                                <td class="px-6 py-4 font-mono text-xs font-bold">1300</td>
                                <td class="px-6 py-4 text-sm font-medium">Inventory</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">@_report.InventoryValue.ToString("N0")</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">0</td>
                            </tr>
                            <tr class="hover:bg-muted/20">
                                <td class="px-6 py-4 font-mono text-xs font-bold">4000</td>
                                <td class="px-6 py-4 text-sm font-medium">Sales Revenue</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">0</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">@_report.TotalRevenue.ToString("N0")</td>
                            </tr>
                            <tr class="hover:bg-muted/20">
                                <td class="px-6 py-4 font-mono text-xs font-bold">5000</td>
                                <td class="px-6 py-4 text-sm font-medium">Cost of Goods Sold</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">@_report.COGS.ToString("N0")</td>
                                <td class="px-6 py-4 text-right font-mono text-sm">0</td>
                            </tr>
                            <tr class="bg-primary/5 font-black">
                                <td colspan="2" class="px-6 py-5 text-right uppercase tracking-widest text-[11px]">Total Balances</td>
                                <td class="px-6 py-5 text-right font-mono">@((_report.CashBalance + _report.InventoryValue + _report.COGS).ToString("N0"))</td>
                                <td class="px-6 py-5 text-right font-mono">@_report.TotalRevenue.ToString("N0")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private DateTime _fromDate = DateTime.Today.AddDays(-30);
    private DateTime _toDate = DateTime.Today;
    private bool _loading = true;
    private FinancialReportDto _report = new();
    private string _activeTab = "Income";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        await Task.Delay(800); // Simulate network latency for that premium feel
        _report = await PharmacyService.GetFinancialReportAsync(_fromDate, _toDate);
        _loading = false;
    }

    private async Task PrintReport()
    {
        var htmlContent = $@"
            <html>
            <head>
                <style>
                    body {{ font-family: 'Inter', sans-serif; padding: 40px; color: #1a1a1a; }}
                    .header {{ border-bottom: 2px solid #000; padding-bottom: 20px; margin-bottom: 30px; }}
                    .title {{ font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; }}
                    .meta {{ font-size: 12px; color: #666; text-transform: uppercase; margin-top: 5px; }}
                    table {{ w-full; border-collapse: collapse; margin-top: 20px; }}
                    th {{ text-align: left; font-size: 10px; text-transform: uppercase; border-bottom: 1px solid #eee; padding: 10px; }}
                    td {{ padding: 10px; border-bottom: 1px solid #f5f5f5; font-size: 13px; }}
                    .total {{ font-weight: 900; border-top: 2px solid #000; border-bottom: 4px double #000; }}
                    .text-right {{ text-align: right; }}
                </style>
            </head>
            <body>
                <div class='header'>
                    <div class='title'>FastPharma LTD</div>
                    <div class='meta'>Financial Performance Report | {_fromDate:MMM dd, yyyy} - {_toDate:MMM dd, yyyy}</div>
                </div>
                <h3>INCOME STATEMENT</h3>
                <table>
                    <tr><th>Description</th><th class='text-right'>Amount (UGX)</th></tr>
                    <tr><td>Total Operating Revenue</td><td class='text-right'>{_report.TotalRevenue:N0}</td></tr>
                    <tr><td>Cost of Goods Sold (Est)</td><td class='text-right'>-{_report.COGS:N0}</td></tr>
                    <tr><td>Operating Expenses (Fixed)</td><td class='text-right'>-{_report.OpEx:N0}</td></tr>
                    <tr class='total'><td>NET OPERATING INCOME</td><td class='text-right'>{_report.NetIncome:N0}</td></tr>
                </table>
            </body>
            </html>";

        await JS.InvokeVoidAsync("eval", $@"
            var printWin = window.open('', '', 'width=800,height=600');
            printWin.document.write(`{htmlContent}`);
            printWin.document.close();
            printWin.focus();
            printWin.print();
            printWin.close();
        ");
    }
}
