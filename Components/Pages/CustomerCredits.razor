@page "/credits"
@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Credit Ledger</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Financial / Accounts Receivable / Customer Debt</p>
    </div>
    <div class="flex gap-4">
        <div class="bg-purple-500/10 border border-purple-500/20 px-4 py-2 rounded-lg flex items-center gap-3">
             <Icon Name="trending-up" Width="18" Height="18" class="text-purple-500" />
             <div>
                <p class="text-[9px] font-black text-purple-500 uppercase tracking-widest leading-none">Total Outsanding</p>
                <p class="text-lg font-black text-foreground">UGX @_credits.Sum(c => c.Balance).ToString("N0")</p>
             </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Ledger Table -->
    <div class="lg:col-span-8 bg-card border border-border rounded-xl shadow-sm overflow-hidden">
        <div class="p-6 border-b border-border bg-muted/10">
            <div class="relative group max-w-sm">
                <Icon Name="search" Width="18" Height="18" class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors" />
                <input type="text" placeholder="Search by customer name..." class="w-full pl-12 pr-4 py-2.5 bg-background border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                    <tr>
                        <th class="px-6 py-5">Customer Identity</th>
                        <th class="px-6 py-5 text-right">Total Spent</th>
                        <th class="px-6 py-5 text-right">Total Paid</th>
                        <th class="px-6 py-5 text-right">Current Balance</th>
                        <th class="px-6 py-5 text-center">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var credit in _credits)
                    {
                        <tr class='hover:bg-muted/30 transition-colors group @(_selectedCredit?.Id == credit.Id ? "bg-primary/5" : "")' @onclick="() => SelectCredit(credit)">
                            <td class="px-6 py-4">
                                <div class="font-bold text-foreground text-sm">@credit.CustomerName</div>
                                <div class="text-[10px] text-muted-foreground font-mono">@credit.Phone</div>
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-medium">UGX @credit.TotalSpent.ToString("N0")</td>
                            <td class="px-6 py-4 text-right text-sm font-medium text-success">UGX @credit.TotalPaid.ToString("N0")</td>
                            <td class="px-6 py-4 text-right">
                                <span class="font-black text-sm @(credit.Balance > 0 ? "text-destructive" : "text-success")">UGX @credit.Balance.ToString("N0")</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <button @onclick="() => OpenPaymentModal(credit)" class="p-2 hover:bg-primary/10 text-primary rounded-lg transition-colors">
                                    <Icon Name="dollar-sign" Width="14" Height="14" StrokeWidth="2.5" />
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Payment History / Details -->
    <div class="lg:col-span-4 space-y-6">
        @if (_selectedCredit != null)
        {
            <div class="bg-card border border-border rounded-xl shadow-sm p-6 animate-fade-in">
                <div class="flex items-center gap-3 mb-6">
                    <div class="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-black">@_selectedCredit.CustomerName[0]</div>
                    <div>
                        <h4 class="font-bold text-foreground text-sm">@_selectedCredit.CustomerName</h4>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-widest">Transaction History</p>
                    </div>
                </div>

                <div class="space-y-4">
                    @if (!_selectedCredit.Payments.Any())
                    {
                        <div class="py-8 text-center text-muted-foreground/40 italic text-xs">No payment records found</div>
                    }
                    @foreach (var payment in _selectedCredit.Payments.OrderByDescending(p => p.PaymentDate))
                    {
                        <div class="flex justify-between items-start p-3 bg-muted/20 rounded-lg border border-border/50">
                            <div>
                                <p class="text-xs font-bold text-foreground">UGX @payment.Amount.ToString("N0")</p>
                                <p class="text-[9px] text-muted-foreground uppercase">@payment.PaymentDate.ToString("MMM dd, yyyy") via @payment.PaymentMethod</p>
                            </div>
                            <div class="h-1.5 w-1.5 rounded-full bg-success"></div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="h-full border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center text-muted-foreground/30 p-12 text-center">
                <Icon Name="history" Width="48" Height="48" class="mb-4" />
                <p class="text-[10px] font-black uppercase tracking-widest">Select a customer to view ledger details</p>
            </div>
        }
    </div>
</div>

@if (_showPaymentModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-background/80 backdrop-blur-sm animate-fade-in">
        <div class="bg-card border border-border shadow-2xl w-full max-w-md rounded-2xl overflow-hidden animate-slide-up">
            <div class="p-6 border-b border-border bg-muted/10">
                <h3 class="text-lg font-bold text-foreground">Settle Credit</h3>
                <p class="text-[10px] text-muted-foreground uppercase tracking-widest font-medium">Payment Processing / Customer: @_selectedCredit?.CustomerName</p>
            </div>
            <div class="p-8 space-y-5">
                <div>
                    <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Amount to Pay (UGX)</label>
                    <input type="number" @bind="_paymentAmount" class="input-field py-4 text-xl font-black text-primary" placeholder="0" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Payment Channel</label>
                    <select @bind="_paymentMethod" class="input-field py-3">
                        <option value="Cash">Cash</option>
                        <option value="Mobile Money">Mobile Money</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                    </select>
                </div>
            </div>
            <div class="p-6 bg-muted/10 border-t border-border flex gap-4">
                <button @onclick="() => _showPaymentModal = false" class="btn-secondary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Cancel</button>
                <button @onclick="ProcessPayment" class="btn-primary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Verify Payment</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerCredit> _credits = new();
    private CustomerCredit? _selectedCredit;
    private bool _showPaymentModal = false;
    private decimal _paymentAmount;
    private string _paymentMethod = "Cash";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _credits = await PharmacyService.GetCustomerCreditsAsync();
    }

    private void SelectCredit(CustomerCredit credit)
    {
        _selectedCredit = credit;
    }

    private void OpenPaymentModal(CustomerCredit credit)
    {
        _selectedCredit = credit;
        _paymentAmount = credit.Balance;
        _showPaymentModal = true;
    }

    private async Task ProcessPayment()
    {
        if (_selectedCredit == null || _paymentAmount <= 0) return;

        var payment = new CreditPayment
        {
            CustomerCreditId = _selectedCredit.Id,
            Amount = _paymentAmount,
            PaymentMethod = _paymentMethod,
            PaymentDate = DateTime.Now
        };

        await PharmacyService.SaveCreditPaymentAsync(payment);
        await LoadData();
        _selectedCredit = _credits.FirstOrDefault(c => c.Id == _selectedCredit.Id);
        _showPaymentModal = false;
        _paymentAmount = 0;
    }
}
