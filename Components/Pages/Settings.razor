@page "/settings"
@using Lucide.Blazor
@using FirstPharmar.Services
@inject IBackupService BackupService

@code {
    private BackupStatus _backupStatus;
    private bool _isBackingUp = false;

    protected override async Task OnInitializedAsync()
    {
        _backupStatus = await BackupService.GetStatusAsync();
    }

    private async Task HandleBackup()
    {
        _isBackingUp = true;
        await BackupService.StartBackupAsync();
        _backupStatus = await BackupService.GetStatusAsync();
        _isBackingUp = false;
    }
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">System Configuration</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Preferences / Security / Localization</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Navigation Tabs (Vertical) -->
    <div class="lg:col-span-3 space-y-1">
        <button class="w-full text-left px-4 py-3 rounded-lg bg-primary/10 text-primary font-bold text-xs uppercase tracking-widest flex items-center gap-3">
            <Icon Name="settings" Width="16" Height="16" /> General
        </button>
        <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-muted text-muted-foreground font-bold text-xs uppercase tracking-widest flex items-center gap-3 transition-colors">
            <Icon Name="shield" Width="16" Height="16" /> Security
        </button>
        <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-muted text-muted-foreground font-bold text-xs uppercase tracking-widest flex items-center gap-3 transition-colors">
            <Icon Name="bell" Width="16" Height="16" /> Notifications
        </button>
        <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-muted text-muted-foreground font-bold text-xs uppercase tracking-widest flex items-center gap-3 transition-colors">
            <Icon Name="database" Width="16" Height="16" /> Database
        </button>
    </div>

    <!-- Main Settings Panel -->
    <div class="lg:col-span-9 bg-card border border-border rounded-xl shadow-sm p-8 animate-fade-in">
        <div class="max-w-2xl space-y-8">
            <section>
                <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-6 flex items-center gap-2">
                    <Icon Name="home" Width="16" Height="16" /> Pharmacy Identity
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Pharmacy Legal Name</label>
                        <input type="text" class="input-field py-3" value="Marvid Pharmacy LTD" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">License Number</label>
                        <input type="text" class="input-field py-3" value="NDA-UG-2026-X882" />
                    </div>
                </div>
            </section>

            <section class="pt-8 border-t border-border">
                <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-6 flex items-center gap-2">
                    <Icon Name="map-pin" Width="16" Height="16" /> Localization
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Currency Display</label>
                        <select class="input-field py-3">
                            <option>UGX - Uganda Shilling</option>
                            <option>USD - US Dollar</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">System Language</label>
                        <select class="input-field py-3">
                            <option>English (International)</option>
                            <option>Swahili</option>
                        </select>
                    </div>
                </div>
            </section>

            <section class="pt-8 border-t border-border">
                 <h3 class="text-xs font-black uppercase tracking-widest text-primary mb-6 flex items-center gap-2">
                    <Icon Name="hard-drive" Width="16" Height="16" /> Backup & Recovery
                </h3>
                <div class="bg-muted/30 p-6 rounded-xl border border-border flex items-center justify-between">
                    <div>
                        <p class="text-sm font-bold text-foreground">Cloud Sync (Google Drive)</p>
                        @if (_backupStatus != null)
                        {
                            <p class="text-[10px] text-muted-foreground uppercase tracking-widest mt-1">
                                Status: <span class='@(_backupStatus.Connected ? "text-success" : "text-warning") font-black'>@_backupStatus.LastStatus</span>
                                @if (_backupStatus.LastBackup.HasValue)
                                {
                                    <span class="mx-2">|</span> <span>Last: @_backupStatus.LastBackup.Value.ToString("dd MMM, HH:mm")</span>
                                }
                            </p>
                        }
                    </div>
                    <button @onclick="HandleBackup" disabled="@_isBackingUp" class="px-4 py-2 bg-primary text-white text-[10px] font-black uppercase tracking-widest rounded-lg disabled:opacity-50 transition-all active:scale-95 flex items-center gap-2">
                        @if (_isBackingUp)
                        {
                            <Icon Name="loader-2" Width="14" Height="14" class="animate-spin" />
                            <span>Processing...</span>
                        }
                        else
                        {
                            <Icon Name="cloud-upload" Width="14" Height="14" />
                            <span>Backup Now</span>
                        }
                    </button>
                </div>
            </section>

            <div class="pt-8 flex justify-end gap-4">
                <button class="btn-secondary px-8 py-3 uppercase tracking-widest text-[10px] font-black">Discard Changes</button>
                <button class="btn-primary px-8 py-3 uppercase tracking-widest text-[10px] font-black">Save Configuration</button>
            </div>
        </div>
    </div>
</div>
