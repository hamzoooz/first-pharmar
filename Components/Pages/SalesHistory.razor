@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-border flex justify-between items-center bg-muted/10">
        <div>
            <h3 class="text-lg font-bold text-foreground">Transaction Archive</h3>
            <p class="text-[10px] text-muted-foreground uppercase tracking-widest font-bold">Financial Records / Sales History</p>
        </div>
        <div class="flex gap-3">
            <button class="btn-secondary flex items-center gap-2 px-4 py-2 text-[10px] font-black uppercase tracking-widest"><Icon Name="download" Width="16" Height="16" /> Export CSV</button>
            <button class="btn-secondary flex items-center gap-2 px-4 py-2 text-[10px] font-black uppercase tracking-widest"><Icon Name="printer" Width="16" Height="16" /> Print Logs</button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-muted/50 text-muted-foreground text-[10px] uppercase font-bold tracking-[0.15em]">
                <tr>
                    <th class="px-6 py-5">Reference ID</th>
                    <th class="px-6 py-5">Timestamp</th>
                    <th class="px-6 py-5 text-center">Batch Size</th>
                    <th class="px-6 py-5 text-right">Adjustments</th>
                    <th class="px-6 py-5 text-right">Final Total</th>
                    <th class="px-6 py-5 text-center">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var sale in _sales)
                {
                    <tr class="hover:bg-muted/30 transition-colors group">
                        <td class="px-6 py-4 font-mono font-bold text-foreground text-xs tracking-tighter">#TXN-@sale.Id.ToString("D5")</td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="text-foreground text-sm font-bold">@sale.SaleDate.ToString("dd MMM yyyy")</span>
                                <span class="text-[10px] text-muted-foreground font-medium uppercase">@sale.SaleDate.ToString("hh:mm tt")</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="bg-secondary/50 text-secondary-foreground text-[10px] font-black px-2 py-0.5 rounded">@sale.Items.Count UNITS</span>
                        </td>
                        <td class="px-6 py-4 text-right text-destructive text-xs font-bold">-(UGX @sale.Discount.ToString("N0"))</td>
                        <td class="px-6 py-4 text-right font-black text-primary text-sm">UGX @sale.TotalAmount.ToString("N0")</td>
                        <td class="px-6 py-4 text-center">
                            <span class="px-3 py-1 bg-success/10 text-success rounded text-[9px] font-black uppercase tracking-widest">Verified</span>
                        </td>
                    </tr>
                }
                @if (!_sales.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-20 text-center text-muted-foreground/30">
                            <Icon Name="history" Width="64" Height="64" class="mx-auto mb-4 opacity-50" />
                            <p class="text-xs font-black uppercase tracking-widest">No transaction data available</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Sale> _sales = new();

    protected override async Task OnInitializedAsync()
    {
        _sales = await PharmacyService.GetSalesAsync();
    }
}
