@using FirstPharmar.Services
@using FirstPharmar.Models
@using Lucide.Blazor
@inject IPharmacyService PharmacyService

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-2xl font-bold text-foreground tracking-tight">Prescriptions Console</h2>
        <p class="text-[11px] text-muted-foreground uppercase tracking-widest font-bold">Archives / Medical Documentation</p>
    </div>
    <button @onclick="OpenAddModal" class="btn-primary flex items-center gap-2 px-6 py-3 uppercase tracking-widest text-[10px]">
        <Icon Name="upload" Width="16" Height="16" StrokeWidth="3" /> Upload Digital Record
    </button>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (_prescriptions == null || !_prescriptions.Any())
    {
        <div class="col-span-full bg-card border border-border border-dashed rounded-2xl p-16 text-center text-muted-foreground/30">
            <Icon Name="file-text" Width="64" Height="64" StrokeWidth="1.5" class="mx-auto mb-4" />
            <p class="text-sm font-bold uppercase tracking-widest">No archival records found</p>
            <p class="text-[10px] uppercase tracking-tight mt-1">Upload verified prescriptions to populate this gallery</p>
        </div>
    }
    else
    {
        @foreach (var item in _prescriptions)
        {
            <div class="bg-card border border-border rounded-xl overflow-hidden flex flex-col group hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 animate-fade-in">
                <div class="h-44 bg-muted/30 flex items-center justify-center relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10 group-hover:scale-110 transition-transform duration-700 flex items-center justify-center">
                        <Icon Name="file-text" Width="120" Height="120" StrokeWidth="1" />
                    </div>
                    @if (string.IsNullOrEmpty(item.ImagePath))
                    {
                        <div class="relative z-10 flex flex-col items-center gap-2">
                             <Icon Name="file-text" Width="40" Height="40" StrokeWidth="1.5" class="text-muted-foreground/40" />
                             <span class="text-[9px] font-bold text-muted-foreground/50 uppercase tracking-widest">No Preview Image</span>
                        </div>
                    }
                    else
                    {
                        <div class="absolute inset-0 bg-primary/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-20 backdrop-blur-[2px]">
                            <button class="bg-white text-primary text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-lg shadow-xl">Review Scan</button>
                        </div>
                        <span class="text-[9px] text-muted-foreground uppercase tracking-tighter opacity-50 relative z-10">Scan ID: @item.Id</span>
                    }
                    <div class="absolute top-4 right-4 z-30">
                        <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest shadow-sm @GetStatusClass(item.Status)">
                            @item.Status
                        </span>
                    </div>
                </div>
                <div class="p-5 flex-1 flex flex-col">
                    <div class="flex-1">
                        <h4 class="font-bold text-foreground text-base mb-1 truncate">@item.CustomerName</h4>
                        <p class="text-[10px] text-muted-foreground font-bold uppercase tracking-widest flex items-center gap-2 mb-4">
                            <div class="h-1 w-1 rounded-full bg-primary"></div> Dr. @(string.IsNullOrEmpty(item.DoctorName) ? "Unspecified" : item.DoctorName)
                        </p>
                    </div>
                    
                    <div class="pt-4 border-t border-border/50 flex justify-between items-center">
                        <span class="text-[10px] font-bold text-muted-foreground">@item.DateUploaded.ToString("MMM dd, yyyy")</span>
                        <div class="flex gap-4">
                            @if (item.Status == "Pending")
                            {
                                <button @onclick='() => UpdateStatus(item, "Approved")' class="text-[10px] font-black uppercase tracking-widest text-success hover:underline">Verify</button>
                            }
                            <button @onclick='() => UpdateStatus(item, "Filled")' class="text-[10px] font-black uppercase tracking-widest text-primary hover:underline">Process</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (_showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-background/80 backdrop-blur-sm animate-fade-in">
        <div class="bg-card border border-border shadow-2xl w-full max-w-xl rounded-2xl overflow-hidden animate-slide-up">
            <div class="p-6 border-b border-border flex justify-between items-center bg-muted/10">
                <div>
                    <h3 class="text-lg font-bold text-foreground">Archival Documentation</h3>
                    <p class="text-[10px] text-muted-foreground uppercase tracking-widest font-medium">System / Prescriptions / New Record</p>
                </div>
                <button @onclick="CloseModal" class="h-8 w-8 rounded-lg flex items-center justify-center hover:bg-muted text-muted-foreground transition-colors">
                    <Icon Name="x" Width="20" Height="20" StrokeWidth="2.5" />
                </button>
            </div>
            <div class="p-8 space-y-6">
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Subject (Customer Name) *</label>
                        <input @bind="_newPrescription.CustomerName" type="text" class="input-field py-3" placeholder="Full legal name..." />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Prescribing Practitioner</label>
                        <input @bind="_newPrescription.DoctorName" type="text" class="input-field py-3" placeholder="Medical doctor name..." />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Source Scan Path</label>
                        <input @bind="_newPrescription.ImagePath" type="text" class="input-field py-3 font-mono text-[11px]" placeholder="Local file URI (C:\Users\...)" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-muted-foreground uppercase tracking-[0.2em] mb-2">Clinical Instructions / Notes</label>
                        <textarea @bind="_newPrescription.Notes" rows="2" class="input-field py-3 resize-none" placeholder="Enter special notes or requirements..."></textarea>
                    </div>
                </div>
            </div>
            <div class="p-6 bg-muted/10 border-t border-border flex gap-4">
                <button @onclick="CloseModal" class="btn-secondary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Discard</button>
                <button @onclick="SavePrescription" class="btn-primary flex-1 py-3 uppercase tracking-[0.2em] text-[10px] font-black">Commit Record</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Prescription> _prescriptions = new();
    private bool _showModal = false;
    private Prescription _newPrescription = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPrescriptions();
    }

    private async Task LoadPrescriptions()
    {
        _prescriptions = await PharmacyService.GetPrescriptionsAsync();
    }

    private void OpenAddModal()
    {
        _newPrescription = new Prescription();
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SavePrescription()
    {
        if (string.IsNullOrWhiteSpace(_newPrescription.CustomerName)) return;
        await PharmacyService.SavePrescriptionAsync(_newPrescription);
        await LoadPrescriptions();
        _showModal = false;
    }

    private async Task UpdateStatus(Prescription p, string status)
    {
        p.Status = status;
        await PharmacyService.SavePrescriptionAsync(p);
        await LoadPrescriptions();
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-orange-100 text-orange-600",
        "Approved" => "bg-green-100 text-green-600",
        "Filled" => "bg-primary-100 text-primary-600",
        _ => "bg-slate-100 text-slate-600"
    };
}
